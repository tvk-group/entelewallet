{
  "name": "entelewallet",
  "version": "0.1.0",
  "private": true,
  "description": "EnteleWALLET Lite and future non-custodial wallet platform for the EnteleKRON ecosystem",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mjs}\"",
    "i18n:check": "node scripts/check-i18n.mjs",
    "security:check": "node scripts/security-check.mjs",
    "ecosystem:export": "node scripts/build-ecosystem-animation-export.mjs",
    "icons:sync": "node scripts/sync-chain-icons.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "^26.1.1",
    "playwright": "1.61.1",
    "prettier": "^3.9.6",
    "turbo": "^2.10.6",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "patchedDependencies": {
      "@rainbow-me/rainbowkit@2.2.11": "patches/@rainbow-me__rainbowkit@2.2.11.patch"
    },
    "overrides": {
      "qr": "0.5.5"
    }
  }
}
