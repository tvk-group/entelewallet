# EnteleWALLET App — Environment Variables
# Copy to apps/web/.env.local for local development.

# Canonical app URL (PWA + auth callbacks)
NEXT_PUBLIC_APP_URL=https://entelewallet.app

# Marketing website (separate repo — entelewallet-site)
NEXT_PUBLIC_MARKETING_URL=https://entelewallet.com

# Alias domains (redirect to entelewallet.app in production)
NEXT_PUBLIC_APP_ALIAS_URL=https://app.entelewallet.com

# WalletConnect (required for WalletConnect-compatible wallets)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Feature flags
NEXT_PUBLIC_ENABLE_WALLET_CONNECT=true
NEXT_PUBLIC_ENABLE_CLAIMS=false
NEXT_PUBLIC_ENABLE_BASE_ACCOUNT=false

# RPC URLs (optional — public defaults used if empty)
NEXT_PUBLIC_ETHEREUM_RPC_URL=
NEXT_PUBLIC_BASE_RPC_URL=

# Alchemy (server-side — ERC-20 discovery + multi-network portfolio)
ALCHEMY_API_KEY=

# Supabase Auth (magic-link sign-in; callback URL must be https://entelewallet.app/auth/callback)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Support reports (optional)
SUPPORT_PROVIDER=supabase
FORMSPREE_ENDPOINT=

# Contact emails (server-side overrides; defaults in @entelewallet/config)
GENERAL_CONTACT_EMAIL=contact@entelewallet.com
SUPPORT_EMAIL=support@entelewallet.com
SECURITY_CONTACT_EMAIL=security@entelewallet.com
LEGAL_CONTACT_EMAIL=legal@entelewallet.com
PRIVACY_CONTACT_EMAIL=privacy@entelewallet.com
PARTNERS_CONTACT_EMAIL=partners@entelewallet.com
PRESS_CONTACT_EMAIL=press@entelewallet.com
