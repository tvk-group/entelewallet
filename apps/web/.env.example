# EnteleWALLET App — Environment Variables
# Copy to apps/web/.env.local for local development.

NEXT_PUBLIC_APP_URL=https://entelewallet.app
NEXT_PUBLIC_APP_ALIAS_URL=https://app.entelewallet.com
NEXT_PUBLIC_MARKETING_URL=https://entelewallet.com

# WalletConnect / Reown (required for WalletConnect — Rainbow, Trust, Ledger, mobile wallets)
# Get your 32-char project ID from https://cloud.reown.com (EnteleWALLET project: 7eb3d2a4…)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=7eb3d2a411af6026d82c5d710156efce
# Aliases also accepted:
# NEXT_PUBLIC_REOWN_PROJECT_ID=
# NEXT_PUBLIC_WC_PROJECT_ID=

# Feature flags
NEXT_PUBLIC_ENABLE_WALLET_CONNECT=true
NEXT_PUBLIC_ENABLE_CLAIMS=false
NEXT_PUBLIC_ENABLE_BASE_ACCOUNT=false

# RPC URLs (optional)
NEXT_PUBLIC_ETHEREUM_RPC_URL=
NEXT_PUBLIC_BASE_RPC_URL=

# CoinGecko (optional — higher rate limits on /api/prices)
COINGECKO_API_KEY=

# CoinMarketCap (optional — silent failover when CoinGecko is unavailable)
COINMARKETCAP_API_KEY=

# Wallet auto-disconnect after inactivity (milliseconds, default 180000 = 3 min)
NEXT_PUBLIC_WALLET_IDLE_MS=180000

# Alchemy (server-side portfolio discovery)
ALCHEMY_API_KEY=

# Supabase — required in production for SIWE nonce storage and distributed rate limiting
# Add https://entelewallet.app/auth/callback to Supabase Redirect URLs
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server security secrets (required in production and public previews — generate with: openssl rand -hex 32)
# RATE_LIMIT_HMAC_SECRET must be a different value from WALLET_VERIFICATION_SECRET.
WALLET_VERIFICATION_SECRET=
RATE_LIMIT_HMAC_SECRET=

# Preview deployments only
PREVIEW_ORIGIN_ALLOWLIST=

# Support reports (optional)
SUPPORT_PROVIDER=supabase
FORMSPREE_ENDPOINT=
