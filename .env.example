# EnteleWALLET Lite Environment Variables

# App URLs
NEXT_PUBLIC_APP_URL=https://entelewallet.app
NEXT_PUBLIC_APP_ALIAS_URL=https://app.entelewallet.com
NEXT_PUBLIC_MARKETING_URL=https://entelewallet.com
NEXT_PUBLIC_SECURITY_URL=https://entelewallet.org
NEXT_PUBLIC_ENTELEKRON_URL=https://entelekron.io

# WalletConnect (required for WalletConnect wallets)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Feature flags
NEXT_PUBLIC_ENABLE_WALLET_CONNECT=true
NEXT_PUBLIC_ENABLE_CLAIMS=false
NEXT_PUBLIC_ENABLE_BASE_ACCOUNT=false

# RPC URLs (optional — public defaults used if empty)
NEXT_PUBLIC_ETHEREUM_RPC_URL=
NEXT_PUBLIC_BASE_RPC_URL=

# Alchemy (server-side — ERC-20 auto-discovery + multi-network portfolio)
ALCHEMY_API_KEY=

# Supabase (optional for Lite phase — dev uses in-memory nonce store)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Contact (@entelewallet.com only for public-facing emails)
GENERAL_CONTACT_EMAIL=contact@entelewallet.com
SUPPORT_EMAIL=support@entelewallet.com
SECURITY_CONTACT_EMAIL=security@entelewallet.com
LEGAL_CONTACT_EMAIL=legal@entelewallet.com
PRIVACY_CONTACT_EMAIL=privacy@entelewallet.com
PARTNERS_CONTACT_EMAIL=partners@entelewallet.com
PRESS_CONTACT_EMAIL=press@entelewallet.com
SUPPORT_PROVIDER=supabase
FORMSPREE_ENDPOINT=
